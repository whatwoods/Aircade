{
  "name": "aircade",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:gen": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,mjs}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "~10.4.27",
    "dotenv": "^16.6.1",
    "drizzle-kit": "~0.21.4",
    "eslint": "~8.57.1",
    "eslint-config-next": "~14.2.35",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "~8.4.49",
    "prettier": "~3.3.3",
    "prettier-plugin-tailwindcss": "~0.6.14",
    "tailwindcss": "~3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.4.5",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "bcryptjs": "~2.4.3",
    "class-variance-authority": "~0.7.1",
    "clsx": "~2.1.1",
    "drizzle-orm": "~0.30.10",
    "ioredis": "~5.4.2",
    "jose": "~5.6.3",
    "lucide-react": "~0.400.0",
    "next": "~14.2.35",
    "postgres": "~3.4.9",
    "react": "~18.3.1",
    "react-dom": "~18.3.1",
    "tailwind-merge": "~2.3.0",
    "zod": "~3.23.8"
  }
}
